vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.vite/

# Sensitive Data Filter
private/
**/private/
private-*
**/private-*
*.private.*
*.private
*.confidential.*
*.sensitive.*
sensitive-*/
confidential-*/
confidential/
# bizarre-pose-estimator: a vendored upstream clone + ~2.7GB of model weights +
# a venv — all local-only. Track ONLY the tooling WE wrote on top of it.
experiments/bizarre-pose-estimator/*
!experiments/bizarre-pose-estimator/_scripts/
experiments/bizarre-pose-estimator/_scripts/*
!experiments/bizarre-pose-estimator/_scripts/exp_monet_pose.py
!experiments/bizarre-pose-estimator/_scripts/pose_batch.py
!experiments/bizarre-pose-estimator/_scripts/pose_data.py
!experiments/bizarre-pose-estimator/_scripts/pose_webm.py
!experiments/bizarre-pose-estimator/RUN_NOTES.md

contents/monet/pose_out/
# playwright MCP scratch
.playwright-mcp/

contents/monet/source/

# scratch analysis renders
/idle*-compare.mp4
contents/monet/archived/sample_animated_webp.webp

# generated videos (Seedance i2v output — heavy, regen via scripts/seedance.py)
/ig/gen/
/ig/posts/
# local secrets (FAL_KEY etc.) — never commit
.env.local

# Wrangler local dev state (miniflare R2/D1/cache emulation) — runtime artifact
.wrangler/

# archived/ — keep source & docs tracked, exclude heavy build artifacts/media
archived/**/node_modules/
archived/**/dist/
archived/**/.wrangler/
archived/console/public/
archived/experiments/**/out/
archived/ig/

# Heavy experiment artifacts (model weights, datasets, renders, sample media) — keep the
# small source/scripts/docs in these dirs tracked, but never the GBs of binaries.
experiments/tha4/
experiments/inpaint-test/
experiments/fast-anime-face/
experiments/flux-edit/
experiments/headpat-poc/
experiments/anime-face-detector/facewipe/
experiments/scail2-monet/inputs/
experiments/webcodecs-poc/*.mp4
xray-*.png

# box-man 3D keypoint sidecars — generated from sam3d-body npz via experiments/box-man/export_kp3d.py
contents/monet/*.s3body3d.json
