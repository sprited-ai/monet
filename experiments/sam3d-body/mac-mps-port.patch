@@ -224,9 +224,20 @@ class MHRHead(nn.Module):
             # Zero out non-hand parameters
             model_params[:, self.nonhand_param_idxs] = 0
 
-        curr_skinned_verts, curr_skel_state = self.mhr(
-            shape_params, model_params, expr_params
-        )
+        # The MHR forward kinematics (compiled pymomentum op) computes in float64, which
+        # MPS does not support. So on MPS ONLY, run the MHR on CPU and hand off across this
+        # boundary (the FK is cheap — the heavy ViT backbone already ran on MPS). On
+        # CUDA/CPU keep the MHR on the model device — no offload, no regression.
+        _dev = model_params.device
+        if _dev.type == "mps":
+            if any(p.device.type != "cpu" for p in self.mhr.parameters()):
+                self.mhr.cpu()
+            _verts, _skel = self.mhr(shape_params.cpu(), model_params.cpu(), expr_params.cpu())
+            curr_skinned_verts, curr_skel_state = _verts.to(_dev), _skel.to(_dev)
+        else:
+            curr_skinned_verts, curr_skel_state = self.mhr(
+                shape_params, model_params, expr_params
+            )
         curr_joint_coords, curr_joint_quats, _ = torch.split(
             curr_skel_state, [3, 4, 1], dim=2
         )
